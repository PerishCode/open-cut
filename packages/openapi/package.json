{
  "name": "@open-cut/openapi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/generated/model/index.d.ts",
      "default": "./dist/generated/model/index.js"
    },
    "./activity": {
      "types": "./dist/generated/activity.d.ts",
      "default": "./dist/generated/activity.js"
    },
    "./agent": {
      "types": "./dist/generated/agent.d.ts",
      "default": "./dist/generated/agent.js"
    },
    "./authorization": {
      "types": "./dist/generated/authorization.d.ts",
      "default": "./dist/generated/authorization.js"
    },
    "./creator": {
      "types": "./dist/generated/creator.d.ts",
      "default": "./dist/generated/creator.js"
    },
    "./editing": {
      "types": "./dist/generated/editing.d.ts",
      "default": "./dist/generated/editing.js"
    },
    "./exports": {
      "types": "./dist/generated/exports.d.ts",
      "default": "./dist/generated/exports.js"
    },
    "./health": {
      "types": "./dist/generated/health.d.ts",
      "default": "./dist/generated/health.js"
    },
    "./media": {
      "types": "./dist/generated/media.d.ts",
      "default": "./dist/generated/media.js"
    },
    "./product": {
      "types": "./dist/generated/product.d.ts",
      "default": "./dist/generated/product.js"
    },
    "./projects": {
      "types": "./dist/generated/projects.d.ts",
      "default": "./dist/generated/projects.js"
    },
    "./runs": {
      "types": "./dist/generated/runs.d.ts",
      "default": "./dist/generated/runs.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.tests.json --noEmit",
    "check": "node scripts/check.ts",
    "format": "biome check --write scripts tests",
    "generate": "node scripts/generate.ts",
    "lint": "biome check scripts tests",
    "test": "node scripts/check.ts && vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "24.13.3",
    "orval": "8.21.0",
    "vitest": "4.1.10"
  }
}
