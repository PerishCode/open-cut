{
  "name": "@open-cut/components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "production": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.tests.json --noEmit",
    "format": "biome check --write src tests vitest.config.ts",
    "lint": "biome check src tests vitest.config.ts",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vitest": "4.1.10"
  }
}
