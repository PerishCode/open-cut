#!/usr/bin/env bash
set -euo pipefail

root=$(git rev-parse --show-toplevel)

for command in pnpm oc-control; do
	if ! command -v "$command" >/dev/null 2>&1; then
		echo "required command is unavailable: $command" >&2
		exit 1
	fi
done

cd "$root"

mapfile -t partially_staged < <(
	comm -12 \
		<(git diff --name-only --no-ext-diff | LC_ALL=C sort) \
		<(git diff --cached --name-only --no-ext-diff | LC_ALL=C sort)
)
if ((${#partially_staged[@]} > 0)); then
	echo "pre-commit refuses partially staged files; stage or restore the remaining changes:" >&2
	printf '  %s\n' "${partially_staged[@]}" >&2
	exit 1
fi

before_format=$(git diff --binary --no-ext-diff | git hash-object --stdin)
mapfile -t go_files < <(git ls-files '*.go')
if ((${#go_files[@]} > 0)); then
	gofmt -w "${go_files[@]}"
fi
pnpm --dir "$root" format
after_format=$(git diff --binary --no-ext-diff | git hash-object --stdin)
if [[ "$before_format" != "$after_format" ]]; then
	echo "pre-commit formatting changed the working tree; review and stage the formatted files, then commit again" >&2
	exit 1
fi

oc-control harness guard --repo "$root"
pnpm --dir "$root" lint
