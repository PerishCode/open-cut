{
  "$defs": {
    "ClientEvent": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegisterEvent"
        },
        {
          "$ref": "#/$defs/HeartbeatEvent"
        },
        {
          "$ref": "#/$defs/EndpointEvent"
        },
        {
          "$ref": "#/$defs/StateEvent"
        },
        {
          "$ref": "#/$defs/ExitingEvent"
        }
      ]
    },
    "CommandEvent": {
      "properties": {
        "command": {
          "$ref": "#/$defs/ControlCommand"
        },
        "type": {
          "const": "command",
          "type": "string"
        }
      },
      "required": [
        "type",
        "command"
      ],
      "type": "object"
    },
    "ControlCommand": {
      "enum": [
        "show",
        "shutdown"
      ],
      "type": "string"
    },
    "Endpoint": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "url": {
          "format": "uri",
          "type": "string"
        }
      },
      "required": [
        "name",
        "url"
      ],
      "type": "object"
    },
    "EndpointEvent": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "type": {
          "const": "endpoint",
          "type": "string"
        },
        "url": {
          "format": "uri",
          "type": "string"
        }
      },
      "required": [
        "type",
        "name",
        "url"
      ],
      "type": "object"
    },
    "ExitingEvent": {
      "properties": {
        "code": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "type": {
          "const": "exiting",
          "type": "string"
        }
      },
      "required": [
        "type",
        "code"
      ],
      "type": "object"
    },
    "HeartbeatEvent": {
      "properties": {
        "type": {
          "const": "heartbeat",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "LifecycleMode": {
      "enum": [
        "production",
        "packaged",
        "dev",
        "harness"
      ],
      "type": "string"
    },
    "RegisterEvent": {
      "properties": {
        "app": {
          "minLength": 1,
          "type": "string"
        },
        "channel": {
          "minLength": 1,
          "type": "string"
        },
        "generation": {
          "minimum": 0,
          "type": "integer"
        },
        "instanceId": {
          "minLength": 1,
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/LifecycleMode"
        },
        "namespace": {
          "minLength": 1,
          "type": "string"
        },
        "sessionId": {
          "minLength": 1,
          "type": "string"
        },
        "source": {
          "minLength": 1,
          "type": "string"
        },
        "type": {
          "const": "register",
          "type": "string"
        }
      },
      "required": [
        "type",
        "channel",
        "namespace",
        "sessionId",
        "generation",
        "app",
        "instanceId",
        "mode",
        "source"
      ],
      "type": "object"
    },
    "RegisteredEvent": {
      "properties": {
        "type": {
          "const": "registered",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "ServerEvent": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegisteredEvent"
        },
        {
          "$ref": "#/$defs/CommandEvent"
        },
        {
          "$ref": "#/$defs/StatusEvent"
        }
      ]
    },
    "SessionStatus": {
      "properties": {
        "app": {
          "minLength": 1,
          "type": "string"
        },
        "connectedAt": {
          "format": "date-time",
          "type": "string"
        },
        "endpoints": {
          "items": {
            "$ref": "#/$defs/Endpoint"
          },
          "type": "array"
        },
        "instanceId": {
          "minLength": 1,
          "type": "string"
        },
        "lastHeartbeat": {
          "format": "date-time",
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/LifecycleMode"
        },
        "ready": {
          "type": "boolean"
        },
        "source": {
          "minLength": 1,
          "type": "string"
        },
        "subject": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "subject",
        "app",
        "instanceId",
        "mode",
        "source",
        "ready",
        "connectedAt",
        "lastHeartbeat"
      ],
      "type": "object"
    },
    "StateEvent": {
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "type": {
          "const": "state",
          "type": "string"
        }
      },
      "required": [
        "type",
        "ready"
      ],
      "type": "object"
    },
    "Status": {
      "properties": {
        "channel": {
          "minLength": 1,
          "type": "string"
        },
        "generation": {
          "minimum": 0,
          "type": "integer"
        },
        "namespace": {
          "minLength": 1,
          "type": "string"
        },
        "revision": {
          "minimum": 0,
          "type": "integer"
        },
        "schema": {
          "const": 1,
          "type": "number"
        },
        "sessionId": {
          "minLength": 1,
          "type": "string"
        },
        "sessions": {
          "items": {
            "$ref": "#/$defs/SessionStatus"
          },
          "type": "array"
        }
      },
      "required": [
        "schema",
        "revision",
        "channel",
        "namespace",
        "sessionId",
        "generation",
        "sessions"
      ],
      "type": "object"
    },
    "StatusEvent": {
      "properties": {
        "status": {
          "$ref": "#/$defs/Status"
        },
        "type": {
          "const": "status",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status"
      ],
      "type": "object"
    }
  },
  "$id": "events.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "$ref": "#/$defs/ClientEvent"
    },
    {
      "$ref": "#/$defs/ServerEvent"
    }
  ]
}
